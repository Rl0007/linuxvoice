[Unit]
Description=LinuxVoice — push-to-talk dictation
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/sg input -c "/usr/bin/python3 %h/linuxvoice/main.py"
WorkingDirectory=%h/linuxvoice
Restart=on-failure
RestartSec=5
Environment=DISPLAY=:0
Environment=XAUTHORITY=%h/.Xauthority

[Install]
WantedBy=default.target
